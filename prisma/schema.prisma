datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum ConsignorType {
  WAREHOUSE
  EXTERNAL
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum ConsignmentStatus {
  DRAFT
  SHIPPED
  PARTIAL_SOLD
  COMPLETED
  RETURNED
  SETTLED
  CANCELLED
}

enum ConsignmentItemStatus {
  ACTIVE
  SOLD_OUT
  RETURNED
  DAMAGED
}

enum SalesReportStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum SettlementStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

enum ReturnCondition {
  GOOD
  DAMAGED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  role      UserRole @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settlements Settlement[]

  @@map("users")
}

model Consignor {
  id            String        @id @default(cuid())
  type          ConsignorType @default(EXTERNAL)
  code          String        @unique
  name          String
  address       String
  managerName   String?
  managerPhone  String?
  contactPerson String?
  phone         String?
  email         String?
  note          String?
  status        RecordStatus  @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  warehouses   Warehouse[]
  consignments Consignment[]

  @@map("consignors")
}

model Product {
  id             String    @id @default(cuid())
  sku            String    @unique
  name           String
  description    String?
  price          Decimal   @db.Decimal(12, 2)
  category       String?
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  consignmentItems    ConsignmentItem[]
  warehouseInventories WarehouseInventory[]
  sales            Sale[]
  returnItems      ConsignmentReturnItem[]
  @@map("products")
}

model Store {
  id            String       @id @default(cuid())
  code          String       @unique
  name          String
  taxCode       String?
  address       String?
  ward          String?
  district      String?
  city          String       @default("TP. Hồ Chí Minh")
  contactPerson String?
  phone         String?
  email         String?
  paymentInfo   String?
  note          String?
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  consignments Consignment[]
  sales        Sale[]

  @@map("stores")
}

model Warehouse {
  id            String       @id @default(cuid())
  code          String       @unique
  name          String
  address       String?
  contactPerson String?
  phone         String?
  note          String?
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  consignorId   String
  consignor     Consignor @relation(fields: [consignorId], references: [id], onDelete: Cascade)
  inventory     WarehouseInventory[]
  consignments Consignment[]

  @@index([consignorId])
  @@map("warehouses")
}

model WarehouseInventory {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@index([warehouseId])
  @@index([productId])
  @@map("warehouse_inventories")
}

model Consignment {
  id                 String            @id @default(cuid())
  code               String            @unique
  consignorId        String
  consignor          Consignor         @relation(fields: [consignorId], references: [id])
  warehouseId        String?
  warehouse          Warehouse?        @relation(fields: [warehouseId], references: [id])
  storeId            String
  store              Store             @relation(fields: [storeId], references: [id])
  sentDate           DateTime
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  reportReceivedAt   DateTime?
  reportNote         String?
  note               String?
  status             ConsignmentStatus @default(DRAFT)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  consignmentItems ConsignmentItem[]
  sales            Sale[]
  settlement       Settlement?
  returns          ConsignmentReturn[]

  @@index([consignorId])
  @@index([warehouseId])
  @@index([storeId])
  @@map("consignments")
}

model ConsignmentItem {
  id               String                @id @default(cuid())
  consignmentId    String
  consignment      Consignment           @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
  productId        String
  product          Product               @relation(fields: [productId], references: [id])
  quantitySent     Int
  quantitySold     Int                   @default(0)
  quantityReturned Int                   @default(0)
  quantityDamaged  Int                   @default(0)
  status           ConsignmentItemStatus @default(ACTIVE)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  sales Sale[]

  @@unique([consignmentId, productId])
  @@index([consignmentId])
  @@map("consignment_items")
}

model Sale {
  id                String            @id @default(cuid())
  code              String            @unique
  quantity          Int
  soldPrice         Decimal           @db.Decimal(12, 2)
  soldAt            DateTime
  note              String?
  status            SalesReportStatus @default(CONFIRMED)
  consignmentId     String
  consignment       Consignment       @relation(fields: [consignmentId], references: [id])
  productId         String
  product           Product           @relation(fields: [productId], references: [id])
  storeId           String
  store             Store             @relation(fields: [storeId], references: [id])
  consignmentItemId String
  consignmentItem   ConsignmentItem   @relation(fields: [consignmentItemId], references: [id])
  salesReportDate   DateTime?
  salesReportRef    String?
  reportedBy        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([consignmentId])
  @@index([productId])
  @@map("sales")
}

model Settlement {
  id                    String           @id @default(cuid())
  code                  String           @unique
  consignmentId         String           @unique
  consignment           Consignment      @relation(fields: [consignmentId], references: [id])
  totalSoldQuantity     Int              @default(0)
  totalReturnedQuantity Int              @default(0)
  totalDamagedQuantity  Int              @default(0)
  dueDate               DateTime?
  note                  String?
  status                SettlementStatus @default(PENDING)
  approvedBy            Int?
  approvedAt            DateTime?
  paidAt                DateTime?
  settledAt             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  approver User? @relation(fields: [approvedBy], references: [id])

  @@index([consignmentId])
  @@map("settlements")
}

model ConsignmentReturn {
  id            String      @id @default(cuid())
  consignmentId String
  consignment   Consignment @relation(fields: [consignmentId], references: [id])
  returnedAt    DateTime
  note          String?
  createdAt     DateTime    @default(now())

  items ConsignmentReturnItem[]

  @@index([consignmentId])
  @@map("consignment_returns")
}

model ConsignmentReturnItem {
  id                  String            @id @default(cuid())
  consignmentReturnId String
  consignmentReturn   ConsignmentReturn @relation(fields: [consignmentReturnId], references: [id], onDelete: Cascade)
  productId           String
  product             Product           @relation(fields: [productId], references: [id])
  quantity            Int
  condition           ReturnCondition   @default(GOOD)
  note                String?

  @@unique([consignmentReturnId, productId])
  @@map("consignment_return_items")
}
